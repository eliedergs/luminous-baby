{
  "name": "luminous-baby",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "validate:posts": "node scripts/validate-posts.mjs",
    "prebuild": "npm run validate:posts",
    "build": "next build",
    "preview": "npx serve out",
